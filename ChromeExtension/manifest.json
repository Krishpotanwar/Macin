{
  "manifest_version": 3,
  "name": "Macin Download Manager",
  "version": "1.1",
  "description": "Send downloads to the Macin app on your Mac.",
  "permissions": [
    "downloads",
    "nativeMessaging",
    "contextMenus",
    "windows"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["confirm.html", "confirm.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
